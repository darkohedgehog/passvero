// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
  PENDING_DELETION
}

enum MembershipRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED
  REMOVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ProductLifecycleStatus {
  ACTIVE
  ARCHIVED
}

enum ProductVersionStatus {
  DRAFT
  READY_FOR_REVIEW
  PUBLISHED
  SUPERSEDED
  DISCARDED
}

enum PassportStatus {
  ACTIVE
  WITHDRAWN
  ARCHIVED
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  /// Application services must normalize email before persistence.
  email           String   @unique
  displayName     String?
  avatarUrl       String?
  preferredLocale String?
  timezone        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships              Membership[]     @relation("UserMemberships")
  membershipsInvited       Membership[]     @relation("MembershipsInvitedByUser")
  invitationsCreated       Invitation[]     @relation("OrganizationInvitationsCreated")
  invitationsAccepted      Invitation[]     @relation("OrganizationInvitationsAccepted")
  productsCreated          Product[]        @relation("ProductCreatedBy")
  productsUpdated          Product[]        @relation("ProductUpdatedBy")
  productsArchived         Product[]        @relation("ProductArchivedBy")
  productVersionsCreated   ProductVersion[] @relation("ProductVersionCreatedBy")
  productVersionsUpdated   ProductVersion[] @relation("ProductVersionUpdatedBy")
  productVersionsPublished ProductVersion[] @relation("ProductVersionPublishedBy")
  passportsWithdrawn       Passport[]       @relation("PassportWithdrawnBy")
}

model Organization {
  id            String             @id @default(uuid()) @db.Uuid
  displayName   String
  legalName     String?
  slug          String?            @unique
  logoUrl       String?
  websiteUrl    String?
  countryCode   String?
  vatNumber     String?
  publicEmail   String?
  billingEmail  String?
  timezone      String?
  defaultLocale String?
  status        OrganizationStatus @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  archivedAt    DateTime?

  memberships     Membership[]     @relation("OrganizationMemberships")
  invitations     Invitation[]     @relation("OrganizationInvitations")
  products        Product[]        @relation("OrganizationProducts")
  productVersions ProductVersion[] @relation("OrganizationProductVersions")
  passports       Passport[]       @relation("OrganizationPassports")

  @@index([status])
  @@index([createdAt])
}

model Membership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  userId         String           @db.Uuid
  role           MembershipRole
  status         MembershipStatus @default(ACTIVE)
  invitedById    String?          @db.Uuid
  joinedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation("OrganizationMemberships", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user         User         @relation("UserMemberships", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  invitedBy    User?        @relation("MembershipsInvitedByUser", fields: [invitedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([invitedById])
  @@index([organizationId, status])
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  /// Application services must normalize email before persistence and comparison.
  email          String
  role           MembershipRole
  status         InvitationStatus @default(PENDING)
  tokenHash      String           @unique
  expiresAt      DateTime
  /// Required when creating an invitation in application services; nullable for historical retention.
  invitedById    String?          @db.Uuid
  acceptedAt     DateTime?
  acceptedById   String?          @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation("OrganizationInvitations", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  invitedBy    User?        @relation("OrganizationInvitationsCreated", fields: [invitedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  acceptedBy   User?        @relation("OrganizationInvitationsAccepted", fields: [acceptedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([email])
  @@index([expiresAt])
  @@index([organizationId, status])
  @@index([invitedById])
  @@index([acceptedById])
}

model Product {
  id                        String                 @id @default(uuid()) @db.Uuid
  organizationId            String                 @db.Uuid
  internalName              String
  sku                       String?
  normalizedSku             String?
  publicCode                String                 @unique
  lifecycleStatus           ProductLifecycleStatus @default(ACTIVE)
  /// Application services must ensure each pointer references a version belonging to this Product.
  currentDraftVersionId     String?                @unique @db.Uuid
  currentPublishedVersionId String?                @unique @db.Uuid
  createdById               String?                @db.Uuid
  updatedById               String?                @db.Uuid
  archivedById              String?                @db.Uuid
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  archivedAt                DateTime?
  lastPublishedAt           DateTime?

  organization            Organization     @relation("OrganizationProducts", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  versions                ProductVersion[] @relation("ProductVersions")
  currentDraftVersion     ProductVersion?  @relation("CurrentDraftVersion", fields: [currentDraftVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  currentPublishedVersion ProductVersion?  @relation("CurrentPublishedVersion", fields: [currentPublishedVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  passport                Passport?        @relation("ProductPassport")
  createdBy               User?            @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedBy               User?            @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  archivedBy              User?            @relation("ProductArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([organizationId, normalizedSku])
  @@index([organizationId, lifecycleStatus])
  @@index([organizationId, updatedAt])
  @@index([createdById])
  @@index([updatedById])
  @@index([archivedById])
}

model ProductVersion {
  id                  String               @id @default(uuid()) @db.Uuid
  productId           String               @db.Uuid
  /// Application services must keep this value equal to Product.organizationId.
  organizationId      String               @db.Uuid
  status              ProductVersionStatus @default(DRAFT)
  sourceLocale        String
  versionNumber       Int?
  versionLabel        String?
  changeSummary       String?
  clonedFromVersionId String?              @db.Uuid
  /// Required by application services at creation; nullable for historical retention.
  createdById         String?              @db.Uuid
  updatedById         String?              @db.Uuid
  publishedById       String?              @db.Uuid
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  reviewReadyAt       DateTime?
  publishedAt         DateTime?
  supersededAt        DateTime?
  discardedAt         DateTime?

  product                    Product          @relation("ProductVersions", fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization               Organization     @relation("OrganizationProductVersions", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clonedFromVersion          ProductVersion?  @relation("ClonedProductVersions", fields: [clonedFromVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  clonedVersions             ProductVersion[] @relation("ClonedProductVersions")
  createdBy                  User?            @relation("ProductVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedBy                  User?            @relation("ProductVersionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  publishedBy                User?            @relation("ProductVersionPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  currentDraftForProduct     Product?         @relation("CurrentDraftVersion")
  currentPublishedForProduct Product?         @relation("CurrentPublishedVersion")

  @@unique([productId, versionNumber])
  @@index([productId, status])
  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
  @@index([publishedAt])
  @@index([clonedFromVersionId])
  @@index([createdById])
  @@index([updatedById])
  @@index([publishedById])
}

model Passport {
  id                      String         @id @default(uuid()) @db.Uuid
  productId               String         @unique @db.Uuid
  /// Application services must keep this value equal to Product.organizationId.
  organizationId          String         @db.Uuid
  status                  PassportStatus @default(ACTIVE)
  defaultLocale           String?
  firstPublishedAt        DateTime
  lastPublishedAt         DateTime?
  withdrawnAt             DateTime?
  withdrawnById           String?        @db.Uuid
  withdrawalReasonCode    String?
  publicWithdrawalMessage String?
  archivedAt              DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  product      Product      @relation("ProductPassport", fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization Organization @relation("OrganizationPassports", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  withdrawnBy  User?        @relation("PassportWithdrawnBy", fields: [withdrawnById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([organizationId, status])
  @@index([firstPublishedAt])
  @@index([lastPublishedAt])
  @@index([withdrawnById])
}
