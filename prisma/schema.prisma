// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
  PENDING_DELETION
}

enum MembershipRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED
  REMOVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ProductLifecycleStatus {
  ACTIVE
  ARCHIVED
}

enum ProductVersionStatus {
  DRAFT
  READY_FOR_REVIEW
  PUBLISHED
  SUPERSEDED
  DISCARDED
}

enum ProductIdentifierType {
  GTIN
  EAN
  UPC
  MPN
  SKU
  CUSTOM
}

enum DocumentStatus {
  PENDING_UPLOAD
  AVAILABLE
  FAILED
  ARCHIVED
}

enum PassportStatus {
  ACTIVE
  WITHDRAWN
  ARCHIVED
}

enum QRCodeStatus {
  PENDING
  ACTIVE
  REVOKED
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  /// Application services must normalize email before persistence.
  email           String   @unique
  displayName     String?
  avatarUrl       String?
  preferredLocale String?
  timezone        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships              Membership[]     @relation("UserMemberships")
  membershipsInvited       Membership[]     @relation("MembershipsInvitedByUser")
  invitationsCreated       Invitation[]     @relation("OrganizationInvitationsCreated")
  invitationsAccepted      Invitation[]     @relation("OrganizationInvitationsAccepted")
  productsCreated          Product[]        @relation("ProductCreatedBy")
  productsUpdated          Product[]        @relation("ProductUpdatedBy")
  productsArchived         Product[]        @relation("ProductArchivedBy")
  productVersionsCreated   ProductVersion[] @relation("ProductVersionCreatedBy")
  productVersionsUpdated   ProductVersion[] @relation("ProductVersionUpdatedBy")
  productVersionsPublished ProductVersion[] @relation("ProductVersionPublishedBy")
  documentsCreated         Document[]       @relation("DocumentCreatedBy")
  documentsUpdated         Document[]       @relation("DocumentUpdatedBy")
  documentsArchived        Document[]       @relation("DocumentArchivedBy")
  passportsWithdrawn       Passport[]       @relation("PassportWithdrawnBy")
}

model Organization {
  id            String             @id @default(uuid()) @db.Uuid
  displayName   String
  legalName     String?
  slug          String?            @unique
  logoUrl       String?
  websiteUrl    String?
  countryCode   String?
  vatNumber     String?
  publicEmail   String?
  billingEmail  String?
  timezone      String?
  defaultLocale String?
  status        OrganizationStatus @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  archivedAt    DateTime?

  memberships     Membership[]     @relation("OrganizationMemberships")
  invitations     Invitation[]     @relation("OrganizationInvitations")
  products        Product[]        @relation("OrganizationProducts")
  productVersions ProductVersion[] @relation("OrganizationProductVersions")
  documents       Document[]       @relation("OrganizationDocuments")
  passports       Passport[]       @relation("OrganizationPassports")

  @@index([status])
  @@index([createdAt])
}

model Membership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  userId         String           @db.Uuid
  role           MembershipRole
  status         MembershipStatus @default(ACTIVE)
  invitedById    String?          @db.Uuid
  joinedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation("OrganizationMemberships", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user         User         @relation("UserMemberships", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  invitedBy    User?        @relation("MembershipsInvitedByUser", fields: [invitedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([invitedById])
  @@index([organizationId, status])
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  /// Application services must normalize email before persistence and comparison.
  email          String
  role           MembershipRole
  status         InvitationStatus @default(PENDING)
  tokenHash      String           @unique
  expiresAt      DateTime
  /// Required when creating an invitation in application services; nullable for historical retention.
  invitedById    String?          @db.Uuid
  acceptedAt     DateTime?
  acceptedById   String?          @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation("OrganizationInvitations", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  invitedBy    User?        @relation("OrganizationInvitationsCreated", fields: [invitedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  acceptedBy   User?        @relation("OrganizationInvitationsAccepted", fields: [acceptedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([email])
  @@index([expiresAt])
  @@index([organizationId, status])
  @@index([invitedById])
  @@index([acceptedById])
}

model Product {
  id                        String                 @id @default(uuid()) @db.Uuid
  organizationId            String                 @db.Uuid
  internalName              String
  sku                       String?
  normalizedSku             String?
  publicCode                String                 @unique
  lifecycleStatus           ProductLifecycleStatus @default(ACTIVE)
  /// Application services must ensure each pointer references a version belonging to this Product.
  currentDraftVersionId     String?                @unique @db.Uuid
  currentPublishedVersionId String?                @unique @db.Uuid
  createdById               String?                @db.Uuid
  updatedById               String?                @db.Uuid
  archivedById              String?                @db.Uuid
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  archivedAt                DateTime?
  lastPublishedAt           DateTime?

  organization            Organization     @relation("OrganizationProducts", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  versions                ProductVersion[] @relation("ProductVersions")
  currentDraftVersion     ProductVersion?  @relation("CurrentDraftVersion", fields: [currentDraftVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  currentPublishedVersion ProductVersion?  @relation("CurrentPublishedVersion", fields: [currentPublishedVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  passport                Passport?        @relation("ProductPassport")
  createdBy               User?            @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedBy               User?            @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  archivedBy              User?            @relation("ProductArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([organizationId, normalizedSku])
  @@index([organizationId, lifecycleStatus])
  @@index([organizationId, updatedAt])
  @@index([createdById])
  @@index([updatedById])
  @@index([archivedById])
}

model ProductVersion {
  id                  String               @id @default(uuid()) @db.Uuid
  productId           String               @db.Uuid
  /// Application services must keep this value equal to Product.organizationId.
  organizationId      String               @db.Uuid
  status              ProductVersionStatus @default(DRAFT)
  sourceLocale        String
  versionNumber       Int?
  versionLabel        String?
  changeSummary       String?
  clonedFromVersionId String?              @db.Uuid
  /// Required by application services at creation; nullable for historical retention.
  createdById         String?              @db.Uuid
  updatedById         String?              @db.Uuid
  publishedById       String?              @db.Uuid
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  reviewReadyAt       DateTime?
  publishedAt         DateTime?
  supersededAt        DateTime?
  discardedAt         DateTime?

  product                    Product              @relation("ProductVersions", fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization               Organization         @relation("OrganizationProductVersions", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clonedFromVersion          ProductVersion?      @relation("ClonedProductVersions", fields: [clonedFromVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  clonedVersions             ProductVersion[]     @relation("ClonedProductVersions")
  createdBy                  User?                @relation("ProductVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedBy                  User?                @relation("ProductVersionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  publishedBy                User?                @relation("ProductVersionPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  currentDraftForProduct     Product?             @relation("CurrentDraftVersion")
  currentPublishedForProduct Product?             @relation("CurrentPublishedVersion")
  translations               ProductTranslation[] @relation("ProductVersionTranslations")
  identifiers                ProductIdentifier[]  @relation("ProductVersionIdentifiers")
  materials                  ProductMaterial[]    @relation("ProductVersionMaterials")
  productDocuments           ProductDocument[]    @relation("ProductVersionDocuments")
  images                     ProductImage[]       @relation("ProductVersionImages")

  @@unique([productId, versionNumber])
  @@index([productId, status])
  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
  @@index([publishedAt])
  @@index([clonedFromVersionId])
  @@index([createdById])
  @@index([updatedById])
  @@index([publishedById])
}

model ProductTranslation {
  id                    String   @id @default(uuid()) @db.Uuid
  productVersionId      String   @db.Uuid
  locale                String
  productName           String
  shortDescription      String?
  description           String?
  technicalDescription  String?
  repairInstructions    String?
  sparePartsInformation String?
  recyclingInstructions String?
  disposalInstructions  String?
  packagingInformation  String?
  safetyInformation     String?
  warrantyInformation   String?
  publicNotes           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  productVersion ProductVersion @relation("ProductVersionTranslations", fields: [productVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([productVersionId, locale])
  @@index([productVersionId])
}

model ProductIdentifier {
  id               String                @id @default(uuid()) @db.Uuid
  productVersionId String                @db.Uuid
  type             ProductIdentifierType
  value            String
  issuingAuthority String?
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  productVersion ProductVersion @relation("ProductVersionIdentifiers", fields: [productVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([productVersionId, type, value])
  @@index([productVersionId])
}

model ProductMaterial {
  id                 String   @id @default(uuid()) @db.Uuid
  productVersionId   String   @db.Uuid
  materialName       String
  category           String?
  /// Percentage ranges and recycled consistency are enforced by manual SQL CHECK constraints.
  percentage         Decimal? @db.Decimal(5, 2)
  isRecycled         Boolean  @default(false)
  recycledPercentage Decimal? @db.Decimal(5, 2)
  supplier           String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  productVersion ProductVersion @relation("ProductVersionMaterials", fields: [productVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([productVersionId])
}

model Document {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String         @db.Uuid
  originalFilename String
  displayName      String?
  fileExtension    String?
  storageProvider  String
  storageBucket    String
  storageKey       String
  mimeType         String
  sizeBytes        BigInt
  /// SHA-256 format, positive file size, and lifecycle consistency are enforced by manual PostgreSQL CHECK constraints.
  checksumSha256   String
  status           DocumentStatus @default(PENDING_UPLOAD)
  uploadedAt       DateTime?
  failedAt         DateTime?
  failureCode      String?
  archivedAt       DateTime?
  createdById      String?        @db.Uuid
  updatedById      String?        @db.Uuid
  archivedById     String?        @db.Uuid
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization     Organization      @relation("OrganizationDocuments", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdBy        User?             @relation("DocumentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedBy        User?             @relation("DocumentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  archivedBy       User?             @relation("DocumentArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  productDocuments ProductDocument[] @relation("DocumentProductVersions")

  @@unique([storageProvider, storageBucket, storageKey])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, updatedAt])
  @@index([checksumSha256])
  @@index([createdById])
  @@index([updatedById])
  @@index([archivedById])
}

model ProductDocument {
  id               String   @id @default(uuid()) @db.Uuid
  productVersionId String   @db.Uuid
  documentId       String   @db.Uuid
  category         String
  locale           String?
  displayLabel     String?
  description      String?
  isPublic         Boolean  @default(true)
  isPrimary        Boolean  @default(false)
  /// Non-negative ordering is enforced by a manual PostgreSQL CHECK constraint in the migration.
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  /// Application services must verify that Document.organizationId equals
  /// ProductVersion.organizationId before creating the association.
  productVersion ProductVersion @relation("ProductVersionDocuments", fields: [productVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  document       Document       @relation("DocumentProductVersions", fields: [documentId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([productVersionId])
  @@index([documentId])
  @@index([productVersionId, category])
  @@index([productVersionId, locale])
  @@index([productVersionId, isPublic, sortOrder])
}

model ProductImage {
  id               String    @id @default(uuid()) @db.Uuid
  productVersionId String    @db.Uuid
  originalFilename String
  fileExtension    String?
  storageProvider  String
  storageBucket    String
  storageKey       String
  mimeType         String
  sizeBytes        BigInt
  /// SHA-256 format, file size, dimensions, MIME allowlist, and non-negative
  /// sort order are enforced by manual PostgreSQL CHECK constraints.
  checksumSha256   String
  width            Int
  height           Int
  altText          String?
  caption          String?
  isPublic         Boolean   @default(true)
  isPrimary        Boolean   @default(false)
  sortOrder        Int       @default(0)
  uploadedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  productVersion ProductVersion @relation("ProductVersionImages", fields: [productVersionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([storageProvider, storageBucket, storageKey])
  @@index([productVersionId])
  @@index([productVersionId, isPublic, sortOrder])
  @@index([productVersionId, isPrimary])
  @@index([checksumSha256])
}

model Passport {
  id                      String         @id @default(uuid()) @db.Uuid
  productId               String         @unique @db.Uuid
  /// Application services must keep this value equal to Product.organizationId.
  organizationId          String         @db.Uuid
  status                  PassportStatus @default(ACTIVE)
  defaultLocale           String?
  firstPublishedAt        DateTime
  lastPublishedAt         DateTime?
  withdrawnAt             DateTime?
  withdrawnById           String?        @db.Uuid
  withdrawalReasonCode    String?
  publicWithdrawalMessage String?
  archivedAt              DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  product      Product      @relation("ProductPassport", fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization Organization @relation("OrganizationPassports", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  withdrawnBy  User?        @relation("PassportWithdrawnBy", fields: [withdrawnById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  qrCode       QRCode?      @relation("PassportQRCode")

  @@index([organizationId, status])
  @@index([firstPublishedAt])
  @@index([lastPublishedAt])
  @@index([withdrawnById])
}

model QRCode {
  id          String       @id @default(uuid()) @db.Uuid
  /// Intentionally one QRCode per Passport for MVP. A future QR-history
  /// migration may relax this uniqueness.
  passportId  String       @unique @db.Uuid
  /// Code format, HTTPS target URL, and lifecycle timestamp consistency are
  /// enforced by manual PostgreSQL CHECK constraints in the migration.
  code        String       @unique
  targetUrl   String       @unique
  status      QRCodeStatus @default(PENDING)
  generatedAt DateTime     @default(now())
  activatedAt DateTime?
  revokedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  passport Passport @relation("PassportQRCode", fields: [passportId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([status])
  @@index([generatedAt])
  @@index([activatedAt])
  @@index([revokedAt])
}
